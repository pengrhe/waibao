.page-hazard {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.status-bar {
  margin-bottom: 20rpx;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 28rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.status-tag::before {
  content: '';
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-done {
  background: var(--success-light);
  color: #059669;
}

.status-done::before {
  background: var(--success);
}

.status-pending {
  background: var(--warning-light);
  color: #b45309;
}

.status-pending::before {
  background: var(--warning);
}

.card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1px solid rgba(0, 0, 0, 0.04);
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
}

.card-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.seq {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: -0.5rpx;
}

.type-tag {
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  background: var(--primary-light);
  color: var(--primary);
}

.desc {
  font-size: 30rpx;
  line-height: 1.55;
  color: var(--text);
  margin-bottom: 28rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  gap: 20rpx;
}

.info-row + .info-row {
  border-top: 1px solid var(--border);
}

.info-label {
  flex-shrink: 0;
  width: 160rpx;
  font-size: 26rpx;
  color: #64748b;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.45;
  word-break: break-all;
}

.info-value-mono {
  font-family: ui-monospace, monospace;
  font-size: 24rpx;
}

.risk-low {
  color: var(--success);
  font-weight: 600;
}

.risk-mid {
  color: var(--warning);
  font-weight: 600;
}

.risk-high {
  color: var(--danger);
  font-weight: 700;
}

.photo-card .section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 20rpx;
}

.photo-row {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.photo-col {
  width: 100%;
  min-width: 0;
}

@media (min-width: 480px) {
  .photo-row {
    flex-direction: row;
    align-items: flex-start;
    gap: 32rpx;
  }

  .photo-col {
    flex: 1;
  }
}

.photo-img {
  width: 100%;
  height: 360rpx;
  border-radius: var(--radius-sm);
  background: var(--bg);
  display: block;
}

.photo-empty {
  height: 360rpx;
  border-radius: var(--radius-sm);
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text3);
}

.upload-dashed {
  height: 360rpx;
  border-radius: var(--radius-sm);
  border: 2rpx dashed var(--border);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: var(--text2);
  background: #fafafa;
}

.upload-dashed:active {
  opacity: 0.85;
  background: var(--primary-light);
  border-color: rgba(99, 102, 241, 0.35);
}

.upload-icon {
  font-size: 56rpx;
  opacity: 0.75;
}

.upload-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

.btn-outline {
  margin-top: 20rpx;
  width: 100%;
  border: 1px solid var(--primary) !important;
  color: var(--primary) !important;
  background: #fff !important;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: var(--radius-sm);
}

.remark-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1px solid var(--border);
}

.remark-text {
  color: #94a3b8;
}

.remark-edit-area {
  margin-top: 12rpx;
}

.remark-input {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--text);
  background: #f8fafc;
  border: 2rpx solid var(--primary);
  border-radius: var(--radius-sm);
  box-sizing: border-box;
}

.remark-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-remark {
  margin: 0 !important;
  padding: 0 24rpx !important;
  height: 60rpx !important;
  line-height: 60rpx !important;
  font-size: 24rpx !important;
  border-radius: 12rpx !important;
  border: none !important;
}

.btn-remark::after {
  border: none !important;
}

.btn-remark-edit {
  background: var(--primary-light) !important;
  color: var(--primary) !important;
  font-weight: 600;
}

.btn-remark-cancel {
  background: #f1f5f9 !important;
  color: #64748b !important;
}

.btn-remark-save {
  background: var(--primary) !important;
  color: #ffffff !important;
  font-weight: 600;
}

.state-tip {
  text-align: center;
  padding: 120rpx 32rpx;
  font-size: 28rpx;
  color: var(--text3);
}

.state-error {
  color: var(--danger);
}

.btn-edit-hazard {
  margin-left: auto;
  background: #eef2ff;
  color: #6366f1;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 24rpx;
  border-radius: 16rpx;
}

.edit-section {
  padding: 8rpx 0;
}

.edit-row {
  display: block;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.edit-label {
  font-size: 24rpx;
  color: #475569;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.input-wrap {
  border: 1rpx solid #e2e8f0;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  background: #f8fafc;
}
.edit-input {
  display: block;
  width: 100%;
  font-size: 28rpx;
  border: none;
  padding: 0;
  margin: 0;
  background: transparent;
}
.edit-textarea {
  display: block;
  width: 100%;
  font-size: 28rpx;
  border: none;
  padding: 0;
  margin: 0;
  background: transparent;
  min-height: 120rpx;
  box-sizing: border-box;
  word-break: break-all;
  line-height: 1.6;
}

.edit-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  margin-top: 16rpx;
}
