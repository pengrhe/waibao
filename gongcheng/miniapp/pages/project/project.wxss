.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 160rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei',
    sans-serif;
  background: #f8fafc;
  box-sizing: border-box;
}

.state {
  padding: 80rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
  border-radius: 12rpx;
}

.state-error {
  color: #ef4444;
}

.card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.06);
}

.project-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 24rpx;
  line-height: 1.35;
}

.row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  font-size: 26rpx;
}

.row:last-child {
  margin-bottom: 0;
}

.row.muted .value,
.row.muted .label {
  color: #94a3b8;
}

.label {
  width: 160rpx;
  flex-shrink: 0;
  color: #64748b;
}

.value {
  flex: 1;
  color: #0f172a;
  word-break: break-all;
}

.value.mono {
  font-variant-numeric: tabular-nums;
}

.divider {
  height: 1rpx;
  background: #e2e8f0;
  margin: 20rpx 0;
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 8rpx 4rpx 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #6366f1;
}

.section-count {
  font-size: 24rpx;
  color: #94a3b8;
}

.scene-card {
  padding-bottom: 20rpx;
}

.scene-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.scene-slot {
  width: 50%;
  padding: 0 10rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scene-inner {
  width: 100%;
  position: relative;
  height: 0;
  padding-bottom: 75%;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f1f5f9;
}

.scene-inner-portrait {
  padding-bottom: 166.67%;
}

.scene-thumb {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.scene-add {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  font-weight: 300;
  color: #6366f1;
  border: 2rpx dashed #c7d2fe;
  border-radius: 12rpx;
  background: #eef2ff;
  box-sizing: border-box;
}

.scene-caption {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.empty-card {
  text-align: center;
  color: #94a3b8;
  font-size: 26rpx;
}

.hazard-card {
  padding: 24rpx;
}

.hazard-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.hazard-seq {
  font-size: 24rpx;
  color: #6366f1;
  font-weight: 600;
}

.hazard-type {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 500;
  color: #0f172a;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.tag-success {
  background: #ecfdf5;
  color: #10b981;
}

.tag-warning {
  background: #fffbeb;
  color: #f59e0b;
}

.hazard-desc {
  display: block;
  font-size: 26rpx;
  color: #475569;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.hazard-photo-row {
  display: flex;
}

.photo-pair {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.photo-slot {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hazard-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f1f5f9;
}

.hazard-thumb-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #94a3b8;
  border: 1rpx solid #e2e8f0;
}

.photo-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.label-done {
  color: #10b981;
}

.footer-spacer {
  height: 24rpx;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  text-align: center;
  font-size: 26rpx;
}

.footer-done {
  background: linear-gradient(180deg, rgba(248, 250, 252, 0) 0%, #f8fafc 28%);
}

.footer-done-text {
  display: inline-block;
  padding: 20rpx 48rpx;
  border-radius: 12rpx;
  background: #ecfdf5;
  color: #10b981;
  font-weight: 600;
  font-size: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(16, 185, 129, 0.2);
}

.footer-hint {
  background: #ffffff;
  border-top: 1rpx solid #e2e8f0;
  color: #64748b;
}

.btn-edit {
  margin-top: 20rpx;
  background: #6366f1;
  color: #fff;
  font-size: 26rpx;
  border-radius: 12rpx;
  padding: 12rpx 30rpx;
}
.edit-row {
  display: block;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.edit-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 6rpx;
}
.input-wrap {
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  background: #f8fafc;
}
.edit-input {
  display: block;
  width: 100%;
  height: 48rpx;
  line-height: 48rpx;
  font-size: 26rpx;
  color: #0f172a;
  border: none;
  padding: 0;
  margin: 0;
  background: transparent;
  box-sizing: border-box;
}
.edit-textarea {
  display: block;
  width: 100%;
  font-size: 26rpx;
  color: #0f172a;
  border: none;
  padding: 0;
  margin: 0;
  background: transparent;
  box-sizing: border-box;
  min-height: 120rpx;
  line-height: 1.6;
  word-break: break-all;
}
.edit-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  justify-content: flex-end;
}
.btn-cancel {
  background: #f1f5f9;
  color: #475569;
  font-size: 26rpx;
  border-radius: 12rpx;
  padding: 12rpx 30rpx;
}
.btn-save {
  background: #10b981;
  color: #fff;
  font-size: 26rpx;
  border-radius: 12rpx;
  padding: 12rpx 30rpx;
}
.btn-add-hazard {
  background: #6366f1;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  margin-left: auto;
}
.btn-add-hazard-big {
  margin-top: 20rpx;
  background: #6366f1;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 40rpx;
  border-radius: 24rpx;
  display: inline-block;
}
.btn-delete-hazard {
  margin-left: auto;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: #fef2f2;
  color: #ef4444;
  font-size: 24rpx;
  font-weight: 700;
}
.nav-card {
  padding: 24rpx 28rpx;
}
.nav-card-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.nav-card-label {
  font-size: 26rpx;
  color: #475569;
  flex: 1;
}
.nav-card-arrow {
  font-size: 36rpx;
  color: #94a3b8;
  margin-left: 16rpx;
}
.picker-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.picker-wrap picker {
  flex: 1;
}
.picker-value {
  font-size: 26rpx;
  color: #0f172a;
  line-height: 48rpx;
}
.picker-value.placeholder {
  color: #94a3b8;
}
.btn-add-member {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #6366f1;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border: 1rpx solid #c7d2fe;
  border-radius: 8rpx;
  background: #eef2ff;
}
