page {
  height: 100%;
  background-color: #000000;
}

.page-root {
  width: 100%;
  height: 100vh;
  position: relative;
  background-color: #000000;
}

.camera-page {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

.camera-full {
  width: 100%;
  height: 100%;
  display: block;
}

/* 上下遮罩 + 取景框边框 */
.crop-mask-top,
.crop-mask-bottom {
  position: absolute;
  left: 0;
  right: 0;
  z-index: 8;
  background: #000000;
  pointer-events: none;
}

.crop-mask-top {
  top: 0;
}

.crop-mask-bottom {
  bottom: 0;
}

.crop-mask-left,
.crop-mask-right {
  position: absolute;
  top: 0;
  bottom: 0;
  z-index: 8;
  background: #000000;
  pointer-events: none;
}

.crop-mask-left {
  left: 0;
}

.crop-mask-right {
  right: 0;
}

.crop-mask-translucent {
  background: rgba(0, 0, 0, 0.55) !important;
}

.crop-border {
  position: absolute;
  left: 0;
  right: 0;
  z-index: 9;
  border-top: 2rpx solid rgba(255, 255, 255, 0.6);
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.6);
  pointer-events: none;
}

.shutter-area {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 20;
  display: flex;
  justify-content: space-around;
  align-items: center;
  pointer-events: auto;
  padding: 0 24px;
  box-sizing: border-box;
}

.shutter-float {
  height: auto !important;
  min-height: 60px;
  padding-top: 8px;
  padding-bottom: calc(8px + env(safe-area-inset-bottom));
  background: rgba(0, 0, 0, 0.5);
}

.shutter-outer {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 4px solid #ffffff;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}

.shutter-inner {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #ffffff;
  border: 2px solid rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.shutter-disabled {
  opacity: 0.5;
}

.tool-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 40px;
}

.tool-label {
  font-size: 10px;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4px;
}

.icon-album {
  width: 24px;
  height: 24px;
  border: 2px solid #ffffff;
  border-radius: 4px;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.album-inner {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  border: 2px solid rgba(255, 255, 255, 0.7);
  box-sizing: border-box;
}

.icon-flip {
  width: 24px;
  height: 24px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.flip-arrow {
  position: absolute;
  width: 10px;
  height: 10px;
  border-top: 2px solid #ffffff;
  border-right: 2px solid #ffffff;
}

.flip-arrow-1 {
  top: 3px;
  right: 3px;
  transform: rotate(45deg);
}

.flip-arrow-2 {
  bottom: 3px;
  left: 3px;
  transform: rotate(225deg);
}

.preview-page {
  width: 100%;
  height: 100vh;
  background-color: #000000;
  display: flex;
  flex-direction: column;
}

.preview-image {
  flex: 1;
  width: 100%;
  min-height: 0;
}

.preview-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 16px 16px;
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
  background: rgba(0, 0, 0, 0.75);
  box-sizing: border-box;
  flex-shrink: 0;
}

.action-btn {
  flex: 1;
  margin: 0 !important;
  padding: 0 !important;
  height: 44px !important;
  line-height: 44px !important;
  font-size: 15px !important;
  border-radius: 8px !important;
  border: none !important;
  text-align: center;
  overflow: hidden;
  white-space: nowrap;
  min-width: 0;
}

.action-btn::after {
  border: none !important;
}

.action-secondary {
  background: rgba(255, 255, 255, 0.18) !important;
  color: #ffffff !important;
}

.action-primary {
  background: #2563eb !important;
  color: #ffffff !important;
  font-weight: 600;
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-box {
  min-width: 140px;
  padding: 20px 24px;
  background: rgba(30, 30, 30, 0.95);
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 28px;
  height: 28px;
  border: 3px solid rgba(255, 255, 255, 0.25);
  border-top-color: #ffffff;
  border-radius: 50%;
  margin-bottom: 12px;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 14px;
  color: #ffffff;
}

/* 时间选择弹框 */

.portrait-hint {
  position: absolute;
  top: 12px;
  left: 0;
  right: 0;
  z-index: 15;
  display: flex;
  justify-content: center;
  pointer-events: none;
}

.portrait-hint-text {
  background: rgba(0, 0, 0, 0.55);
  color: rgba(255, 255, 255, 0.9);
  font-size: 13px;
  padding: 6px 16px;
  border-radius: 16px;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 900;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-dialog {
  width: 300px;
  background: #1e1e1e;
  border-radius: 12px;
  padding: 20px 18px 16px;
  box-sizing: border-box;
}

.picker-title {
  font-size: 16px;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  margin-bottom: 18px;
}

.picker-row {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.picker-label {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.7);
  width: 40px;
  flex-shrink: 0;
}

.picker-value {
  flex: 1;
  height: 36px;
  line-height: 36px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 6px;
  padding: 0 12px;
  font-size: 15px;
  color: #ffffff;
}

.picker-hint {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.45);
  text-align: center;
  margin: 4px 0 14px;
}

.picker-actions {
  display: flex;
  gap: 10px;
}

.picker-btn {
  flex: 1;
  margin: 0 !important;
  padding: 0 !important;
  height: 40px !important;
  line-height: 40px !important;
  font-size: 14px !important;
  border-radius: 7px !important;
  border: none !important;
  text-align: center;
}

.picker-btn::after {
  border: none !important;
}

.picker-cancel {
  background: rgba(255, 255, 255, 0.15) !important;
  color: #ffffff !important;
}

.picker-confirm {
  background: #2563eb !important;
  color: #ffffff !important;
  font-weight: 600;
}
