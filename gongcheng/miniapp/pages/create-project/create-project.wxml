<view class="page-create">
  <view class="form-card">
    <view class="form-row">
      <text class="form-label required">项目名称</text>
      <view class="input-wrap">
        <textarea
          class="form-textarea"
          value="{{form.name}}"
          data-field="name"
          bindinput="onInput"
          placeholder="请输入场所/项目名称"
          placeholder-class="input-placeholder"
          auto-height
          maxlength="200"
        />
      </view>
    </view>

    <view class="form-row">
      <text class="form-label">街道</text>
      <view class="input-wrap">
        <input class="form-input" value="{{form.street}}" data-field="street" bindinput="onInput" placeholder="如：观澜街道" placeholder-class="input-placeholder" />
      </view>
    </view>

    <view class="form-row">
      <text class="form-label">地址</text>
      <view class="input-wrap">
        <textarea
          class="form-textarea"
          value="{{form.address}}"
          data-field="address"
          bindinput="onInput"
          placeholder="详细地址"
          placeholder-class="input-placeholder"
          auto-height
          maxlength="500"
        />
      </view>
    </view>

    <view class="form-row">
      <text class="form-label">联系人</text>
      <view class="input-wrap">
        <input class="form-input" value="{{form.contact}}" data-field="contact" bindinput="onInput" placeholder="联系人姓名" placeholder-class="input-placeholder" />
      </view>
    </view>

    <view class="form-row">
      <text class="form-label">电话</text>
      <view class="input-wrap">
        <input class="form-input" value="{{form.phone}}" data-field="phone" bindinput="onInput" placeholder="联系电话" placeholder-class="input-placeholder" type="number" />
      </view>
    </view>

    <view class="form-row">
      <text class="form-label">类别</text>
      <view class="input-wrap">
        <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
          <view class="picker-value {{form.category ? '' : 'placeholder'}}">
            {{form.category || '请选择类别'}}
          </view>
        </picker>
      </view>
    </view>

    <block wx:if="{{projectType === 'wenti'}}">
      <view class="form-divider"></view>

      <view class="form-row">
        <text class="form-label">报告编号</text>
        <view class="input-wrap">
          <input class="form-input" value="{{form.report_code}}" data-field="report_code" bindinput="onInput" placeholder="如 YFJC-2025-001" placeholder-class="input-placeholder" />
        </view>
      </view>

      <view class="form-row">
        <text class="form-label">经营面积</text>
        <view class="input-wrap">
          <input class="form-input" value="{{form.area}}" data-field="area" bindinput="onInput" placeholder="单位：㎡" placeholder-class="input-placeholder" />
        </view>
      </view>

      <view class="form-row">
        <text class="form-label">所在楼层</text>
        <view class="input-wrap">
          <input class="form-input" value="{{form.floor_info}}" data-field="floor_info" bindinput="onInput" placeholder="如：1F" placeholder-class="input-placeholder" />
        </view>
      </view>

      <view class="form-row">
        <text class="form-label">排查人员</text>
        <view class="input-wrap">
          <textarea
            class="form-textarea"
            value="{{form.inspectors}}"
            data-field="inspectors"
            bindinput="onInput"
            placeholder="多人用逗号分隔"
            placeholder-class="input-placeholder"
            auto-height
            maxlength="200"
          />
        </view>
      </view>

      <view class="form-row">
        <text class="form-label">检查日期</text>
        <view class="input-wrap">
          <input class="form-input" value="{{form.check_date}}" data-field="check_date" bindinput="onInput" placeholder="如 2025.6.10" placeholder-class="input-placeholder" />
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="form-divider"></view>

      <view class="form-row">
        <text class="form-label">建设单位</text>
        <view class="input-wrap">
          <input class="form-input" value="{{form.build_unit}}" data-field="build_unit" bindinput="onInput" placeholder="建设单位名称" placeholder-class="input-placeholder" />
        </view>
      </view>

      <view class="form-row">
        <text class="form-label">施工单位</text>
        <view class="input-wrap">
          <input class="form-input" value="{{form.construct_unit}}" data-field="construct_unit" bindinput="onInput" placeholder="施工单位名称" placeholder-class="input-placeholder" />
        </view>
      </view>

      <view class="form-row">
        <text class="form-label">监理单位</text>
        <view class="input-wrap">
          <input class="form-input" value="{{form.supervise_unit}}" data-field="supervise_unit" bindinput="onInput" placeholder="监理单位名称" placeholder-class="input-placeholder" />
        </view>
      </view>

      <view class="form-row">
        <text class="form-label">核销人员</text>
        <view class="input-wrap">
          <input class="form-input" value="{{form.inspectors}}" data-field="inspectors" bindinput="onInput" placeholder="核销人员" placeholder-class="input-placeholder" />
        </view>
      </view>

      <view class="form-row">
        <text class="form-label">核销日期</text>
        <view class="input-wrap">
          <input class="form-input" value="{{form.check_date}}" data-field="check_date" bindinput="onInput" placeholder="如 2026年04月17日" placeholder-class="input-placeholder" />
        </view>
      </view>
    </block>
  </view>

  <view class="btn-area">
    <button class="btn-submit" bindtap="onSubmit" disabled="{{submitting}}">
      {{submitting ? '创建中…' : '创建项目'}}
    </button>
  </view>
</view>
