.page {
  height: 100vh;
  background: #f8fafc;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.body-wrap {
  display: flex;
  flex: 1;
  overflow: hidden;
}
.tab-bar {
  width: 160rpx;
  flex-shrink: 0;
  background: #fff;
  padding: 16rpx 0;
  border-right: 1rpx solid #e2e8f0;
  box-sizing: border-box;
}
.tab-item {
  display: block;
  padding: 20rpx 16rpx;
  margin: 0 12rpx 12rpx;
  font-size: 24rpx;
  color: #64748b;
  border-radius: 12rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.tab-active {
  background: #6366f1;
  color: #fff;
  font-weight: 600;
}
.body-content {
  flex: 1;
  padding: 0 24rpx 120rpx;
}
.state { text-align: center; padding: 60rpx 0; font-size: 28rpx; color: #94a3b8; }
.empty { display: flex; flex-direction: column; align-items: center; gap: 20rpx; }
.btn-add {
  display: inline-block;
  background: #6366f1;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 32rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}
.btn-add-inline {
  background: #6366f1;
  color: #fff;
  font-size: 26rpx;
  padding: 14rpx 32rpx;
  border-radius: 24rpx;
}
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(15,23,42,0.05);
}
.record-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.record-loc { font-size: 28rpx; font-weight: 600; color: #0f172a; }
.record-result { font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 8rpx; }
.result-pass { background: #ecfdf5; color: #10b981; }
.result-fail { background: #fef2f2; color: #ef4444; }
.record-row {
  display: flex;
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 8rpx;
}
.record-label {
  width: 140rpx;
  color: #94a3b8;
  flex-shrink: 0;
}
.record-remark {
  color: #64748b;
  font-size: 24rpx;
}
.record-photo-row {
  margin: 12rpx 0;
}
.record-thumb {
  width: 200rpx;
  height: 150rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
}
.record-thumb-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #c7d2fe;
  color: #6366f1;
  font-size: 24rpx;
}
.record-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}
.btn-sm {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}
.btn-edit-sm { background: #eef2ff; color: #6366f1; }
.btn-photo-sm { background: #f0fdf4; color: #10b981; }
.btn-del-sm { background: #fef2f2; color: #ef4444; }
.form-card { border: 2rpx solid #c7d2fe; }
.form-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 20rpx;
}
.form-row {
  display: block;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.form-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 6rpx;
}
.input-wrap {
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  background: #f8fafc;
}
.form-input {
  display: block;
  width: 100%;
  height: 48rpx;
  line-height: 48rpx;
  font-size: 26rpx;
  color: #0f172a;
  border: none;
  padding: 0;
  margin: 0;
  background: transparent;
}
.form-hint {
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 16rpx;
}
.result-picks {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}
.result-pick {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #e2e8f0;
  color: #475569;
}
.pick-active {
  background: #eef2ff;
  border-color: #6366f1;
  color: #6366f1;
  font-weight: 600;
}
.pick-fail {
  background: #fef2f2;
  border-color: #ef4444;
  color: #ef4444;
}
.form-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  margin-top: 24rpx;
}
.btn-cancel {
  background: #f1f5f9;
  color: #475569;
  font-size: 26rpx;
  border-radius: 12rpx;
  padding: 12rpx 30rpx;
}
.btn-save {
  background: #10b981;
  color: #fff;
  font-size: 26rpx;
  border-radius: 12rpx;
  padding: 12rpx 30rpx;
}
