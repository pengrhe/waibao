.page {
  height: 100vh;
  background: #f8fafc;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.body-wrap {
  display: flex;
  flex: 1;
  overflow: hidden;
}
.tab-bar {
  width: 180rpx;
  flex-shrink: 0;
  background: #fff;
  padding: 16rpx 0;
  border-right: 1rpx solid #e2e8f0;
  box-sizing: border-box;
}
.tab-item {
  display: block;
  padding: 20rpx 12rpx;
  margin: 0 12rpx 12rpx;
  font-size: 24rpx;
  color: #64748b;
  border-radius: 12rpx;
  text-align: center;
}
.tab-active {
  background: #6366f1;
  color: #fff;
  font-weight: 600;
}
.body-content {
  flex: 1;
  padding: 0 24rpx 160rpx;
}
.state { text-align: center; padding: 60rpx 0; font-size: 28rpx; color: #94a3b8; }
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(15,23,42,0.04);
}
.item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.item-seq {
  font-size: 26rpx;
  font-weight: 600;
  color: #6366f1;
  flex-shrink: 0;
}
.item-text {
  font-size: 24rpx;
  color: #475569;
  line-height: 1.5;
  margin-top: 12rpx;
}
.item-result {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}
.result-pass { background: #ecfdf5; color: #10b981; }
.result-fail { background: #fef2f2; color: #ef4444; }
.result-neutral { background: #f1f5f9; color: #64748b; }
.save-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #e2e8f0;
}
.btn-save-all {
  background: #6366f1;
  color: #fff;
  font-size: 30rpx;
  border-radius: 16rpx;
  padding: 20rpx 0;
  width: 100%;
}
.btn-save-all[disabled] {
  background: #c7d2fe;
  color: #fff;
}
