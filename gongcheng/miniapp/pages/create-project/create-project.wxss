.page-create {
  min-height: 100vh;
  padding: 24rpx 24rpx 160rpx;
  background: #f8fafc;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 16rpx 28rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-row {
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.04);
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #64748b;
  margin-bottom: 8rpx;
}

.form-label.required::before {
  content: '*';
  color: #ef4444;
  margin-right: 4rpx;
}

.input-wrap {
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  background: #f8fafc;
}

.form-input {
  display: block;
  width: 100%;
  height: 48rpx;
  line-height: 48rpx;
  font-size: 26rpx;
  color: #0f172a;
  border: none;
  padding: 0;
  margin: 0;
  background: transparent;
  box-sizing: border-box;
}

.form-textarea {
  display: block;
  width: 100%;
  font-size: 26rpx;
  color: #0f172a;
  border: none;
  padding: 0;
  margin: 0;
  background: transparent;
  box-sizing: border-box;
  min-height: 48rpx;
  line-height: 1.6;
}

.input-placeholder {
  color: #94a3b8;
  font-size: 26rpx;
}

.picker-value {
  font-size: 26rpx;
  color: #0f172a;
  line-height: 48rpx;
}

.picker-value.placeholder {
  color: #94a3b8;
}

.form-divider {
  height: 1px;
  background: #e2e8f0;
  margin: 20rpx -28rpx;
}

.btn-area {
  padding: 32rpx 0;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 16rpx;
  border: none;
  letter-spacing: 2rpx;
}

.btn-submit[disabled] {
  opacity: 0.6;
}

.btn-submit::after {
  border: none;
}
